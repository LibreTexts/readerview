{
  "name": "readerview",
  "version": "1.0.0",
  "description": "",
  "main": "readerview.js",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:prod && npm run build:css",
    "build:dev": "rollup -c",
    "build:prod": "rollup -c --environment BUILD:production",
    "build:css": "postcss readerview.css -o dist/readerview.min.css",
    "build:analyze": "rollup -c --environment BUILD:production,ANALYZE:true",
    "clean": "rm dist/readerview.*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LibreTexts/readerview.git"
  },
  "author": "LibreTexts",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/LibreTexts/readerview/issues"
  },
  "homepage": "https://github.com/LibreTexts/readerview#readme",
  "dependencies": {
    "localstorage-slim": "^2.7.1",
    "micromodal": "^0.4.10"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "autoprefixer": "^10.4.19",
    "cssnano": "^7.0.1",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "rollup": "^4.18.0",
    "rollup-plugin-visualizer": "^5.12.0"
  }
}
